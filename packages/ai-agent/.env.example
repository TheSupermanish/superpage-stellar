# LLM Provider: "anthropic", "openai", or "google"
LLM_PROVIDER=google
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...
# LLM_MODEL=gemini-2.0-flash  # optional, defaults per provider

# Merchant
MERCHANT_URL=http://localhost:3001

# Chain selection
X402_CHAIN=stellar-testnet    # or: flow-testnet, base-sepolia, etc.

# EVM Wallet (required for EVM chains)
# WALLET_PRIVATE_KEY=0x...

# Stellar Wallet (required for Stellar chains)
STELLAR_SECRET_KEY=S...
# HORIZON_URL=https://horizon-testnet.stellar.org  # optional, defaults per network

# ERC-8004 Trustless Identity (EVM only, optional)
# ERC8004_AGENT_ID=1

# Behavior
MAX_STEPS=20
AUTO_APPROVE_PAYMENTS=false
VERBOSE=true
